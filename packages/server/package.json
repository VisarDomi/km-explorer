{
  "name": "@km-explorer/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "restart": "systemctl --user restart km-explorer-backend",
    "stop": "systemctl --user stop km-explorer-backend",
    "logs": "journalctl --user -u km-explorer-backend -f",
    "status": "systemctl --user status km-explorer-backend"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "express": "^4.21.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
